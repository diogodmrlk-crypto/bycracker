
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Permite que qualquer usuário logado leia seu próprio perfil ou que um admin leia qualquer um
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Permite que o usuário crie seu próprio perfil na primeira vez. 
      // Se for o admin mestre (kizarudono), permite definir como admin.
      allow create: if isSignedIn() && request.auth.uid == userId && (
        request.resource.data.role != 'admin' || 
        request.auth.token.email == 'kizarudono@kizaru.ffz'
      );
      
      // Apenas o próprio usuário ou admin pode atualizar (admin não pode tirar o próprio acesso aqui por segurança básica)
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Apenas admins podem deletar ou listar usuários
      allow delete, list: if isAdmin();
    }

    match /system/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
