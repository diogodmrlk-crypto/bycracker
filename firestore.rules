
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Leitura: O próprio usuário ou Admin
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Listagem: Apenas Admin
      allow list: if isAdmin();
      
      // Criação: Admin pode criar qualquer um. 
      allow create: if isAdmin() || (
        isSignedIn() && 
        request.auth.uid == userId && 
        request.resource.data.role == 'user'
      );
      
      // Atualização: Admin tem controle total. 
      // Usuário comum NÃO pode mudar o próprio campo isActive nem o próprio role.
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.auth.uid == userId && 
        request.resource.data.role == resource.data.role &&
        request.resource.data.isActive == resource.data.isActive
      );
      
      // Deleção: Apenas Admin
      allow delete: if isAdmin();
    }

    match /system/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
