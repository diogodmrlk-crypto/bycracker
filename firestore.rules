
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HEADTRICK KIZARU - SECURITY RULES CONFIGURATION
     * 
     * Atualizado para permitir acesso de leitura/escrita aos perfis
     * se o usuário estiver autenticado (mesmo que anonimamente)
     * para facilitar o uso do login bypass kizaru/171.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      // Permite leitura e escrita se o usuário estiver logado.
      // Em produção, userId deveria ser igual a request.auth.uid.
      allow get, update: if isSignedIn();
      
      // Regra para criação inicial do documento (ex: administrador criando novo usuário)
      allow create: if isSignedIn();
      
      // Proíbe listagem pública para evitar raspagem de dados
      allow list: if false;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
