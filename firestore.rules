
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Regra fundamental: o ID do documento DEVE ser o UID do usuário
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Permitir que o admin kizarudono crie seu próprio perfil inicialmente
      allow create: if isSignedIn() && request.auth.uid == userId && (
        request.resource.data.role != 'admin' || 
        request.auth.token.email == 'kizarudono@kizaru.ffz'
      );
      
      // Apenas o dono ou admin pode atualizar. O próprio usuário não pode mudar sua role.
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );
      
      // Listagem e deleção restritas a admins
      allow list, delete: if isAdmin();
    }

    match /system/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
