
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Entidade de usuário com UID como ID de documento.",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "removerTremedeiraActive": { "type": "boolean" },
        "estabilizarMiraActive": { "type": "boolean" },
        "sensiSemCongelamentoActive": { "type": "boolean" },
        "cleanActive": { "type": "boolean" }
      },
      "required": ["username", "role", "isActive"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{uid}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Perfis de usuário onde o ID do documento é o UID do Firebase Auth."
        }
      }
    ]
  }
}
