
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Entidade de usuário expandida para incluir controle administrativo e licenciamento.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isActive": { "type": "boolean" },
        "creationTimestamp": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "expirationDate": { "type": "string", "format": "date-time" },
        "planType": { "type": "string", "enum": ["basic", "premium", "lifetime"] },
        "removerTremedeiraActive": { "type": "boolean" },
        "estabilizarMiraActive": { "type": "boolean" },
        "sensiSemCongelamentoActive": { "type": "boolean" },
        "cleanActive": { "type": "boolean" },
        "forceLogout": { "type": "boolean" }
      },
      "required": ["id", "username", "role", "isActive"]
    },
    "Settings": {
      "title": "Settings",
      "type": "object",
      "properties": {
        "maintenanceMode": { "type": "boolean" },
        "globalAnnouncement": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Documentos de usuário com campos de autorização e role."
        }
      },
      {
        "path": "/system/config",
        "definition": {
          "entityName": "Settings",
          "schema": { "$ref": "#/backend/entities/Settings" },
          "description": "Configurações globais do sistema."
        }
      }
    ]
  }
}
